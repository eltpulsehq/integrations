{
  "family": "eltpulse-gateway",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::REPLACE_ACCOUNT_ID:role/REPLACE_ECS_EXECUTION_ROLE",
  "taskRoleArn": "arn:aws:iam::REPLACE_ACCOUNT_ID:role/REPLACE_ECS_TASK_ROLE",
  "containerDefinitions": [
    {
      "name": "gateway",
      "image": "ghcr.io/eltpulsehq/gateway:latest",
      "essential": true,
      "environment": [
        {
          "name": "ELTPULSE_CONTROL_PLANE_URL",
          "value": "https://app.eltpulse.dev"
        },
        {
          "name": "ELTPULSE_RUNNER",
          "value": "ecs"
        },
        {
          "name": "ELTPULSE_EXECUTE_RUNS",
          "value": "1"
        },
        {
          "name": "ELTPULSE_WORKER_IMAGE",
          "value": "ghcr.io/eltpulsehq/gateway-worker:latest"
        },
        {
          "name": "ELTPULSE_ECS_CLUSTER",
          "value": "REPLACE_CLUSTER_ARN_OR_NAME"
        },
        {
          "name": "ELTPULSE_ECS_TASK_DEFINITION",
          "value": "REPLACE_WORKER_TASK_DEFINITION"
        },
        {
          "name": "ELTPULSE_ECS_SUBNETS",
          "value": "REPLACE_SUBNET_ID_1,REPLACE_SUBNET_ID_2"
        },
        {
          "name": "AWS_REGION",
          "value": "REPLACE_REGION"
        }
      ],
      "secrets": [
        {
          "name": "ELTPULSE_AGENT_TOKEN",
          "valueFrom": "arn:aws:secretsmanager:REPLACE_REGION:REPLACE_ACCOUNT_ID:secret:REPLACE_SECRET_NAME"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/eltpulse-gateway",
          "awslogs-region": "REPLACE_REGION",
          "awslogs-stream-prefix": "gateway"
        }
      }
    }
  ]
}
